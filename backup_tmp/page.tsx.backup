function DemoModal({ onClose }: { onClose: () => void }) {
  const demos = [
    { id: 1, title: 'Dobranoc mały traktorze', duration: '0:30', color: 'from-emerald-500 to-green-500', url: 'https://pub-8791828a7ff445cb857b07c14f225bd7.r2.dev/storys/Kr%C3%B3tkie/Dobranoc%20ma%C5%82y%20traktorze/dobranoc%20ma%C5%82y%20traktorze.m4a' },
    { id: 2, title: 'Festiwal latających wysp', duration: '0:30', color: 'from-blue-500 to-indigo-500', url: 'https://pub-8791828a7ff445cb857b07c14f225bd7.r2.dev/storys/Spokojne/Festival%20lataj%C4%85cych%20wysp/FESTIWAL%20LATAJ%C4%84CYCH%20WYSP.m4a' },
    { id: 3, title: 'Ekspedycja na Wyspę...', duration: '0:30', color: 'from-purple-500 to-pink-500', url: 'https://pub-8791828a7ff445cb857b07c14f225bd7.r2.dev/storys/Przygodowe/Ekspedycja%20na%20Wysp%C4%99%20Cyfrowego%20Zegarmistrza/Ekspedycja%20na%20Wysp%C4%99%20Cyfrowego%20Zegarmistrza.m4a' },
  ];

  const [playingId, setPlayingId] = useState<number | null>(null);
  const audioRef = useRef<HTMLAudioElement | null>(null);

  useEffect(() => {
    let interval: NodeJS.Timeout;
    if (playingId && audioRef.current) {
      interval = setInterval(() => {
        if (audioRef.current && audioRef.current.currentTime >= 30) {
          audioRef.current.pause();
          setPlayingId(null);
        }
      }, 1000);
    }
    return () => clearInterval(interval);
  }, [playingId]);

  const togglePlay = (id: number, url: string) => {
    if (playingId === id) {
      audioRef.current?.pause();
      setPlayingId(null);
    } else {
      if (audioRef.current) {
        audioRef.current.src = url;
        audioRef.current.play().catch(() => console.log('Błąd odtwarzania audio'));
      }
      setPlayingId(id);
    }
  };

  return (
    <motion.div 
      initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
      className="fixed inset-0 z-[100] flex items-center justify-center p-4 md:p-6"
    >
      <div className="absolute inset-0 bg-[#0a0a0e]/90 backdrop-blur-md" onClick={onClose} />
      <motion.div 
        initial={{ scale: 0.95, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.95, y: 20 }}
        className="relative w-full max-w-lg bg-[#111118] border border-white/10 rounded-3xl p-6 md:p-8 shadow-2xl overflow-hidden"
      >
        <div className="absolute top-0 right-0 w-[200px] h-[200px] bg-purple-500/10 blur-[60px] pointer-events-none" />
        
        <div className="flex justify-between items-center mb-8 relative z-10">
          <div>
            <h3 className="text-2xl font-bold text-white mb-1">Posłuchaj Próbek</h3>
            <p className="text-slate-400 text-sm">Zanurz się w świecie "Na Dobranoc"</p>
          </div>
          <button onClick={onClose} className="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors">
            <X className="w-5 h-5 text-white" />
          </button>
        </div>

        <div className="space-y-4 relative z-10">
          {demos.map(demo => (
            <div key={demo.id} className="flex items-center gap-4 p-4 rounded-2xl bg-white/5 hover:bg-white/10 border border-white/5 transition-colors">
              <button 
                onClick={() => togglePlay(demo.id, demo.url)}
                className={`w-12 h-12 rounded-full bg-gradient-to-br ${demo.color} flex items-center justify-center shadow-lg hover:scale-105 transition-transform shrink-0`}
              >
                {playingId === demo.id ? <Pause className="w-5 h-5 text-white" fill="currentColor" /> : <PlayCircle className="w-5 h-5 text-white" />}
              </button>
              <div className="flex-1">
                <h4 className="font-bold text-white text-base leading-tight mb-1">{demo.title}</h4>
                <p className="text-xs text-slate-400 font-medium tracking-wide">{demo.duration}</p>
              </div>
              {playingId === demo.id && (
                <div className="flex gap-1 items-end h-5">
                  <span className="w-1.5 bg-purple-400 h-full animate-[bounce_1s_infinite]" />
                  <span className="w-1.5 bg-pink-400 h-3 animate-[bounce_1.2s_infinite]" />
                  <span className="w-1.5 bg-blue-400 h-4 animate-[bounce_0.8s_infinite]" />
                </div>
              )}
            </div>
          ))}
        </div>

        <audio ref={audioRef} onEnded={() => setPlayingId(null)} />
      </motion.div>
    </motion.div>
  );
}

export default function LandingPage() {
  const { scrollY } = useScroll();
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const [showDemoModal, setShowDemoModal] = useState(false);

  const handleSmoothScroll = (e: React.MouseEvent<HTMLElement>, id: string) => {
    e.preventDefault();
    if (isMenuOpen) {
      setIsMenuOpen(false);
      // Jeśli klikamy z menu, strona jest pomniejszona (scale 0.9).
      // Czekamy 600ms aż wróci do 1.0, żeby współrzędne Y sekcji przeliczyły się poprawnie!
      setTimeout(() => {
        const element = document.getElementById(id);
        if (element) element.scrollIntoView({ behavior: 'smooth' });
      }, 600);
    } else {
      const element = document.getElementById(id);
      if (element) element.scrollIntoView({ behavior: 'smooth' });
    }
  };

  // Blokowanie scrolla pod spodem, gdy menu jest otwarte
  useEffect(() => {
    if (isMenuOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = 'unset';
    }
    return () => { document.body.style.overflow = 'unset'; };
  }, [isMenuOpen]);
  
  // Parallax: lewy telefon szybko w górę, prawy powoli w dół
  const yParallax1 = useTransform(scrollY, [0, 1000], [0, -400]);
  const yParallax2 = useTransform(scrollY, [0, 1000], [0, 250]);
  
  // Przenikanie tekstu (Fade out)
  const textOpacity = useTransform(scrollY, [0, 400], [1, 0]);
  const textScale = useTransform(scrollY, [0, 400], [1, 0.95]);

  return (
    <div className="min-h-screen bg-[#0a0a0e] overflow-x-hidden selection:bg-purple-500/30">
      
      {/* MODAL DEMO AUDIO */}
      <AnimatePresence>
        {showDemoModal && <DemoModal onClose={() => setShowDemoModal(false)} />}
      </AnimatePresence>

      {/* WYSUWANE MENU BOCZNE */}
      <AnimatePresence>
        {isMenuOpen && (
          <>
            {/* Niewidzialna nakładka zamykająca po kliknięciu poza menu */}
            <motion.div 
              initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
              onClick={() => setIsMenuOpen(false)}
              className="fixed inset-0 z-[90] bg-transparent cursor-pointer"
            />
            
            <motion.div
              initial={{ x: '100%', opacity: 0 }}
              animate={{ x: 0, opacity: 1 }}
              exit={{ x: '100%', opacity: 0 }}
              transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}
              style={{ willChange: 'transform, opacity' }}
              className="fixed top-0 right-0 bottom-0 w-[85vw] md:w-[450px] bg-gradient-to-br from-[#1a1a24]/95 to-[#0a0a0e]/95 backdrop-blur-3xl border-l border-t border-white/10 rounded-l-[2rem] md:rounded-l-[3rem] z-[100] p-8 md:p-12 flex flex-col shadow-[inset_1px_1px_0_rgba(255,255,255,0.1),-40px_0_100px_rgba(0,0,0,0.9)] overflow-hidden"
            >
              {/* Animowany błysk (Glass Sweep) przechodzący co kilka sekund */}
              <motion.div 
                animate={{ left: ['-100%', '200%', '200%'] }}
                transition={{ repeat: Infinity, duration: 6, ease: "linear", times: [0, 0.3, 1] }}
                className="absolute top-0 bottom-0 w-[60%] bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-[-25deg] pointer-events-none z-0"
              />

              {/* Przycisk Zamknij */}
              <div className="flex justify-end mb-12 relative z-10">
                <button onClick={() => setIsMenuOpen(false)} className="w-14 h-14 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 hover:rotate-90 transition-all border border-white/5">
                  <X className="w-6 h-6 text-white" />
                </button>
              </div>

              {/* Główne Linki Nawigacyjne */}
              <div className="flex flex-col gap-6 mb-auto text-2xl md:text-3xl font-bold tracking-tight relative z-10">
                <a href="#features" onClick={(e) => handleSmoothScroll(e, 'features')} className="text-slate-300 hover:text-white hover:translate-x-2 transition-all">O aplikacji Na dobranoc</a>
                <Link href="/dlaczego-my" onClick={() => setIsMenuOpen(false)} className="text-slate-300 hover:text-white hover:translate-x-2 transition-all">Dlaczego my?</Link>
                <a href="#video" onClick={(e) => handleSmoothScroll(e, 'video')} className="text-slate-300 hover:text-white hover:translate-x-2 transition-all">Jak to działa</a>
                <a href="#pricing" onClick={(e) => handleSmoothScroll(e, 'pricing')} className="text-slate-300 hover:text-white hover:translate-x-2 transition-all">Kupno</a>
                <a href="#contact" onClick={(e) => handleSmoothScroll(e, 'contact')} className="text-slate-300 hover:text-white hover:translate-x-2 transition-all">Kontakt</a>
              </div>

              {/* Logowanie (Strefa Klienta) */}
              <div className="mt-12 mb-12 relative z-10">
                <p className="text-xs text-slate-500 font-bold uppercase tracking-widest mb-4 ml-2">Strefa Klienta</p>
                <Link href="/logowanie" className="group w-full py-6 rounded-2xl bg-gradient-to-r from-purple-600 to-pink-600 text-white font-extrabold text-lg shadow-[0_0_30px_rgba(236,72,153,0.2)] hover:shadow-[0_0_50px_rgba(236,72,153,0.4)] hover:scale-[1.02] transition-all flex items-center justify-center gap-3 relative overflow-hidden">
                  <LogIn className="w-6 h-6 group-hover:-translate-y-1 transition-transform" /> Zaloguj się do Panelu
                </Link>
              </div>

              {/* Linki Prawne */}
              <div className="flex flex-col gap-4 text-sm font-medium text-slate-500 border-t border-white/10 pt-8 relative z-10">
                <Link href="/regulamin" className="hover:text-purple-400 transition-colors">Regulamin usługi</Link>
                <Link href="/prywatnosc" className="hover:text-purple-400 transition-colors">Polityka prywatności</Link>
              </div>
            </motion.div>
          </>
        )}
      </AnimatePresence>

      {/* GŁÓWNA STRONA - przesuwa się i pomniejsza */}
      <motion.div
        animate={{ 
          x: isMenuOpen ? '-4vw' : 0, 
          scale: isMenuOpen ? 0.9 : 1, 
          opacity: isMenuOpen ? 0.4 : 1 
        }}
        transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}
        className="w-full min-h-screen pointer-events-auto rounded-[2rem]"
        style={{ 
          transformOrigin: 'left top', // Kotwiczymy do górnego rogu, aby uniknąć luki na górze
          willChange: 'transform, opacity',
          pointerEvents: isMenuOpen ? 'none' : 'auto' // Blokujemy klikanie na stronę w tle
        }}
      >
      
      {/* Tła Globalne - rozciągnięte na całą stronę */}
      <div className="absolute top-0 left-0 w-full h-full z-0 pointer-events-none">
        {/* Kosmiczne Niebo z prawej strony */}
        <div className="absolute top-0 right-0 w-full lg:w-[55%] h-full overflow-hidden">
          <StarrySky />
        </div>
        
        {/* Piękne, przenikające się tło (Kolor z litery 'z') po lewej stronie */}
        <div className="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-[#f68087]/20 from-[30%] via-[#f68087]/5 via-[65%] to-transparent">
          <div className="absolute top-[0%] left-[-10%] w-[800px] h-[800px] bg-[#f68087]/15 blur-[150px] rounded-full" />
          <div className="absolute top-[20%] left-[10%] w-[600px] h-[600px] bg-[#f68087]/10 blur-[150px] rounded-full" />
          <div className="absolute top-[40%] left-[-5%] w-[800px] h-[800px] bg-[#f68087]/15 blur-[150px] rounded-full" />
          <div className="absolute top-[60%] left-[15%] w-[600px] h-[600px] bg-[#f68087]/10 blur-[150px] rounded-full" />
          <div className="absolute top-[80%] left-[-10%] w-[800px] h-[800px] bg-[#f68087]/15 blur-[150px] rounded-full" />
        </div>
      </div>

      {/* Nawigacja (dst.design style) */}
      <nav className="relative z-50 flex items-center justify-between px-6 lg:px-12 py-8 max-w-[1600px] mx-auto">
        
        {/* Lewa strona - Powiększone Logo 3D z podtytułem */}
        <div className="flex items-center gap-6 cursor-pointer group perspective-[1000px]">
          <Logo3D />
          <div className="flex flex-col justify-center">
            <span className="text-[28px] font-serif font-black tracking-tighter leading-none text-white">na.dobranoc</span>
            <span className="text-[10px] font-bold tracking-[0.2em] text-slate-400 uppercase mt-1">Aplikacja do usypiania</span>
          </div>
        </div>

        {/* Środek - Linki z rozwijanym menu */}
        <div className="hidden lg:flex items-center gap-8">
          <a href="#features" onClick={(e) => handleSmoothScroll(e, 'features')} className="text-[13px] font-bold tracking-wide text-white hover:text-purple-400 transition-colors flex items-center gap-1">
            O aplikacji <ChevronRight className="w-3 h-3 rotate-90 opacity-50" />
          </a>
          <Link href="/dlaczego-my" className="text-[13px] font-bold tracking-wide text-white hover:text-purple-400 transition-colors">
            Dlaczego my?
          </Link>
          <a href="#opinie" onClick={(e) => handleSmoothScroll(e, 'opinie')} className="text-[13px] font-bold tracking-wide text-white hover:text-purple-400 transition-colors">Opinie</a>
          <a href="#pricing" onClick={(e) => handleSmoothScroll(e, 'pricing')} className="text-[13px] font-bold tracking-wide text-white hover:text-purple-400 transition-colors">Cennik</a>
          <a href="#faq" onClick={(e) => handleSmoothScroll(e, 'faq')} className="text-[13px] font-bold tracking-wide text-white hover:text-purple-400 transition-colors">FAQ</a>
          <a href="#contact" onClick={(e) => handleSmoothScroll(e, 'contact')} className="text-[13px] font-bold tracking-wide text-white hover:text-purple-400 transition-colors">Kontakt</a>
        </div>

        {/* Prawa strona - Przyciski akcji */}
        <div className="flex items-center gap-4">
          <Link href="/checkout" className="hidden sm:flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white text-[13px] font-bold rounded-full hover:scale-105 transition-transform shadow-[0_0_20px_rgba(168,85,247,0.4)]">
            Kup Premium <span className="text-lg leading-none mb-0.5">+</span>
          </Link>
          
          <button 
            onClick={() => setIsMenuOpen(true)}
            className="flex items-center gap-3 px-6 py-3.5 bg-transparent border border-white/20 text-white text-[13px] font-bold rounded-full hover:bg-white/10 transition-colors"
          >
            <div className="flex flex-col gap-[4px]">
              <span className="w-5 h-[2px] bg-white rounded-full"></span>
              <span className="w-5 h-[2px] bg-white rounded-full"></span>
              <span className="w-3 h-[2px] bg-white rounded-full"></span>
            </div>
            MENU
          </button>
        </div>
      </nav>

      {/* Hero Section */}
      <main className="relative z-10 min-h-[90vh] flex flex-col items-center justify-center pt-10 pb-24 px-6 max-w-6xl mx-auto text-center">
        
        {/* Lewy Telefon 3D Parallax */}
        <motion.div 
          style={{ y: yParallax1 }}
          className="absolute left-[-25%] md:left-[-10%] top-[10%] pointer-events-none z-0"
        >
          <motion.div 
            animate={{ 
              y: [0, -30, 0], 
              rotateZ: [-15, -12, -15], 
              rotateX: [15, 20, 15], 
              rotateY: [20, 25, 20] 
            }}
            transition={{ duration: 7, repeat: Infinity, ease: "easeInOut" }}
            style={{ transformStyle: 'preserve-3d' }}
          >
            <PhoneMockup src="/app-home.jpg" alt="Ekran Główny" glowColor="rgba(168,85,247,0.2)" />
          </motion.div>
        </motion.div>

        {/* Prawy Telefon 3D Parallax */}
        <motion.div 
          style={{ y: yParallax2 }}
          className="absolute right-[-25%] md:right-[-10%] top-[20%] pointer-events-none z-20 hidden lg:block"
        >
          <motion.div 
            animate={{ 
              y: [0, 40, 0], 
              rotateZ: [10, 15, 10], 
              rotateX: [20, 15, 20], 
              rotateY: [-25, -20, -25] 
            }}
            transition={{ duration: 9, repeat: Infinity, ease: "easeInOut", delay: 1 }}
            style={{ transformStyle: 'preserve-3d' }}
          >
            <PhoneMockup src="/app-player.jpg" alt="Odtwarzacz" glowColor="rgba(56,189,248,0.2)" />
          </motion.div>
        </motion.div>

        {/* Tekst Hero */}
        <motion.div style={{ opacity: textOpacity, scale: textScale }} className="relative z-10 flex flex-col items-center">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
            className="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-12 shadow-[0_0_30px_rgba(168,85,247,0.15)]"
          >
            <span className="flex h-2 w-2 rounded-full bg-purple-500 animate-pulse" />
            <span className="text-xs font-semibold tracking-widest text-slate-300 uppercase">Aplikacja niezależna</span>
          </motion.div>

          <motion.h1 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.1 }}
            className="text-5xl md:text-7xl lg:text-[6rem] font-bold tracking-tight mb-8 leading-[1.1] text-white drop-shadow-xl"
          >
            Twój sposób na <br/>
            <span className="font-serif italic tracking-normal text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-pink-400 to-orange-400 drop-shadow-[0_0_40px_rgba(168,85,247,0.4)]">
              dobry sen dziecka
            </span>
          </motion.h1>

          <motion.p 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.2 }}
            className="text-lg md:text-2xl text-slate-400 max-w-3xl mx-auto mb-14 font-light leading-relaxed drop-shadow-md"
          >
            Zmień wieczorne usypianie w magiczny rytuał. Zaawansowana platforma, która za pomocą kojących dźwięków uspokoi nawet najbardziej aktywne maluchy.
          </motion.p>

          <motion.div 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.3 }}
            className="flex flex-col sm:flex-row gap-6 items-center justify-center"
          >
            <button className="relative group px-10 py-5 bg-gradient-to-r from-purple-600 to-blue-600 text-white font-bold rounded-full overflow-hidden shadow-lg shadow-purple-600/30">
              <div className="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out" />
              <span className="relative flex items-center gap-3">
                <Download className="w-5 h-5" /> Kup Dostęp Premium
              </span>
            </button>
            
            <button 
              onClick={() => setShowDemoModal(true)}
              className="group px-10 py-5 bg-[#0a0a0e]/50 backdrop-blur-xl border border-white/20 text-white font-medium rounded-full hover:bg-white/5 transition-colors flex items-center gap-3"
            >
              <Music className="w-5 h-5 text-slate-300 group-hover:text-white transition-colors" /> Posłuchaj Demo
            </button>
          </motion.div>
        </motion.div>
      </main>

      {/* Sekcja Funkcji (Korzyści) */}
      <section id="features" className="scroll-mt-24 relative z-30 py-32 px-6 lg:px-12 max-w-[1400px] mx-auto mt-12 bg-[#0a0a0e]">
        <div className="mb-20 max-w-2xl relative">
          <div className="absolute -left-10 top-1/2 -translate-y-1/2 w-[200px] h-[200px] bg-purple-600/20 blur-[100px] rounded-full pointer-events-none" />
          
          <h2 className="relative text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight">
            O aplikacji <span className="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Na dobranoc</span>
          </h2>
          <p className="relative text-xl text-slate-400 font-light leading-relaxed">Najbardziej zaawansowana aplikacja do usypiania na rynku. Przemyślana architektura stworzona przez ekspertów od snu.</p>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          
          {/* Duży blok - Tryb Offline */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-gradient-to-br from-[#1a1a24] to-[#0a0a0e] border border-white/10 hover:border-purple-500/40 md:col-span-2 transition-all duration-500 overflow-hidden shadow-2xl"
          >
            <div className="absolute inset-0 bg-gradient-to-r from-purple-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
            <div className="relative z-10 flex flex-col h-full justify-between">
              <div className="flex justify-between items-start mb-8">
                <div className="p-4 rounded-2xl bg-purple-500/10 border border-purple-500/20">
                  <WifiOff className="w-10 h-10 text-purple-400" />
                </div>
                <span className="text-xs font-bold uppercase tracking-widest text-purple-500/50">Priorytet Zdrowia</span>
              </div>
              <div>
                <h3 className="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Tryb Samolotowy</h3>
                <p className="text-slate-400 leading-relaxed font-light text-lg max-w-lg">
                  Wieczorem liczy się spokój. Dlatego wszystkie ulubione bajki możesz pobrać wcześniej i odtwarzać całkowicie offline, bez Internetu, powiadomień i rozpraszających bodźców.
                </p>
              </div>
            </div>
          </motion.div>

          {/* Mały blok - Biały szum */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ delay: 0.1, duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-[#111118] border border-white/5 hover:border-pink-500/30 transition-all duration-500 overflow-hidden"
          >
            <div className="absolute top-0 right-0 w-32 h-32 bg-pink-500/10 blur-[50px]" />
            <div className="relative z-10 flex flex-col h-full">
              <VolumeX className="w-10 h-10 text-pink-400 mb-8" />
              <h3 className="text-2xl font-bold text-white mb-4 tracking-tight">Dźwięki Tła</h3>
              <p className="text-slate-400 leading-relaxed font-light">
                Naturalne pejzaże dźwiękowe oraz kojące szumy zostały dobrane tak, aby stworzyć bezpieczną i relaksującą atmosferę, wspierając spokojne zasypianie każdego wieczoru.
              </p>
            </div>
          </motion.div>

          {/* Mały blok - Bajki */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ delay: 0.2, duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-[#111118] border border-white/5 hover:border-blue-500/30 transition-all duration-500 overflow-hidden"
          >
            <Sparkles className="w-10 h-10 text-blue-400 mb-8" />
            <h3 className="text-2xl font-bold text-white mb-4 tracking-tight">Biblioteka Bajek</h3>
            <p className="text-slate-400 leading-relaxed font-light">
              Każda bajka została stworzona z myślą o spokojnym zakończeniu dnia. Delikatna narracja, wyciszająca atmosfera i starannie dobrane historie pomagają dziecku naturalnie przejść od aktywności do snu.
            </p>
          </motion.div>

          {/* Duży blok - Licencja */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ delay: 0.3, duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-gradient-to-bl from-[#1a1a24] to-[#0a0a0e] border border-white/10 hover:border-indigo-500/40 md:col-span-2 transition-all duration-500 overflow-hidden shadow-2xl"
          >
            <div className="absolute inset-0 bg-gradient-to-l from-indigo-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
            <div className="relative z-10 flex flex-col md:flex-row gap-10 items-center justify-between h-full">
              <div className="flex-1">
                <div className="flex items-center gap-4 mb-6">
                  <ShieldCheck className="w-8 h-8 text-indigo-400" />
                  <span className="text-sm font-bold uppercase tracking-widest text-indigo-400">Jeden abonament</span>
                </div>
                <h3 className="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Pełna Kontrola</h3>
                <p className="text-slate-400 leading-relaxed font-light text-lg max-w-xl">
                  Twoja licencja, urządzenia i subskrypcja są zawsze pod ręką. Intuicyjny panel pozwala zarządzać wszystkim w jednym miejscu, zapewniając wygodę i pełną kontrolę nad kontem.
                </p>
              </div>
              <div className="w-full md:w-auto p-6 rounded-2xl bg-white/5 border border-white/10 flex flex-col gap-4 min-w-[200px]">
                <div className="flex items-center justify-between text-sm">
                  <span className="text-slate-400 font-medium">Urządzenie Mamy</span>
                  <Check className="w-4 h-4 text-emerald-400" />
                </div>
                <div className="w-full h-[1px] bg-white/10" />
                <div className="flex items-center justify-between text-sm">
                  <span className="text-slate-400 font-medium">Tablet (Pokój Dziecka)</span>
                  <Check className="w-4 h-4 text-emerald-400" />
                </div>
                <div className="w-full h-[1px] bg-white/10" />
                <div className="flex items-center justify-between text-sm">
                  <span className="text-slate-400 font-medium">Telefon Taty</span>
                  <Check className="w-4 h-4 text-emerald-400" />
                </div>
              </div>
            </div>
          </motion.div>
          
        </div>
      </section>

      {/* Dedykowana Galeria Zrzutów Ekranu */}
