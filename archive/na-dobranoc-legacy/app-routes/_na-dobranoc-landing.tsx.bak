          >
            <PhoneMockup src="/app-home.jpg" alt="Ekran Główny" glowColor="rgba(168,85,247,0.2)" className="w-[180px] h-[375px] md:w-[280px] md:h-[580px]" />
          </motion.div>
        </motion.div>

        {/* Prawy Telefon 3D Parallax */}
        <motion.div 
          style={{ y: yParallax2 }}
          className="absolute right-[-15%] sm:right-[-10%] md:right-[-10%] top-[20%] pointer-events-none z-0"
        >
          <motion.div 
            animate={{ 
              y: [0, 40, 0], 
              rotateZ: [10, 15, 10], 
              rotateX: [20, 15, 20], 
              rotateY: [-25, -20, -25] 
            }}
            transition={{ duration: 9, repeat: Infinity, ease: "easeInOut", delay: 1 }}
            style={{ transformStyle: 'preserve-3d' }}
          >
            <PhoneMockup src="/app-player.jpg" alt="Odtwarzacz" glowColor="rgba(56,189,248,0.2)" className="w-[180px] h-[375px] md:w-[280px] md:h-[580px]" />
          </motion.div>
        </motion.div>

        {/* Tekst Hero */}
        <motion.div style={{ opacity: textOpacity, scale: textScale }} className="relative z-10 flex flex-col items-center mb-20 md:mb-40">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
            className="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8 md:mb-12 shadow-[0_0_30px_rgba(168,85,247,0.15)]"
          >
            <span className="flex h-2 w-2 rounded-full bg-purple-500 animate-pulse" />
            <span className="text-xs font-semibold tracking-widest text-slate-300 uppercase">Aplikacja niezależna</span>
          </motion.div>

          <motion.h1 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.1 }}
            className="text-5xl md:text-7xl lg:text-[6rem] font-bold tracking-tight mb-8 md:mb-8 leading-[1.1] text-white drop-shadow-xl"
          >
            Twój sposób na <br/>
            <span className="font-serif italic tracking-normal text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-pink-400 to-orange-400 drop-shadow-[0_0_40px_rgba(168,85,247,0.4)]">
              dobry sen dziecka
            </span>
          </motion.h1>

          <motion.p 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.2 }}
            className="text-lg md:text-2xl text-slate-400 max-w-3xl mx-auto mb-8 md:mb-14 font-light leading-relaxed drop-shadow-md hidden sm:block"
          >
            Zmień wieczorne usypianie w magiczny rytuał. Zaawansowana platforma, która za pomocą kojących dźwięków uspokoi nawet najbardziej aktywne maluchy.
          </motion.p>

          <motion.div 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.3 }}
            className="flex flex-col items-center gap-4 sm:gap-6 w-full mt-4 sm:mt-0"
          >
            <div className="flex flex-row gap-2 sm:gap-6 items-center justify-center w-full max-w-[360px] sm:max-w-none mx-auto">
              <Link href="/checkout" className="relative group px-3 py-3 sm:px-10 sm:py-5 bg-gradient-to-r from-purple-600 to-blue-600 text-white font-bold text-[11px] sm:text-base rounded-full overflow-hidden shadow-[0_0_30px_rgba(168,85,247,0.3)] flex flex-1 sm:flex-none items-center justify-center hover:scale-105 transition-transform text-center whitespace-nowrap sm:w-auto">
                <div className="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out" />
                <span className="relative flex items-center justify-center gap-1.5 sm:gap-3">
                  <Download className="w-5 h-5 hidden sm:inline-block" />
                  <span className="hidden sm:inline">Kup Dostęp Dożywotni</span>
                  <span className="sm:hidden">Dostęp Dożywotni</span>
                </span>
              </Link>
              
              <button 
                onClick={() => setShowDemoModal(true)}
                className="group px-3 py-3 sm:px-10 sm:py-5 bg-[#0a0a0e]/50 backdrop-blur-xl border border-white/20 text-white font-medium text-[11px] sm:text-base rounded-full hover:bg-white/5 transition-colors flex flex-1 sm:flex-none items-center justify-center gap-1.5 sm:gap-3 text-center whitespace-nowrap sm:w-auto"
              >
                <Music className="w-5 h-5 text-slate-300 group-hover:text-white transition-colors hidden sm:inline-block" /> Posłuchaj Demo
              </button>
            </div>
            
            <Link href={isLoggedIn ? "/dashboard" : "/logowanie"} className="relative group p-[2px] rounded-full overflow-hidden shadow-[0_0_30px_rgba(251,146,60,0.1)] hover:shadow-[0_0_40px_rgba(251,146,60,0.4)] hover:scale-[1.02] transition-all flex w-full max-w-[360px] sm:w-[400px]">
              {/* Spinning Neon Ray - the "k" in "dziecka" color is #fb923c */}
              <div className="absolute inset-0 bg-[#fb923c]/20" />
              <div 
                className="absolute top-1/2 left-1/2 w-[300%] h-[300%] -translate-x-1/2 -translate-y-1/2 bg-[conic-gradient(from_0deg,transparent_0_270deg,#fb923c_360deg)] opacity-90 group-hover:opacity-100 animate-[spin_3s_linear_infinite]" 
              />
              <div className="relative bg-[#0a0a0e] px-4 py-3 sm:px-10 sm:py-5 rounded-full flex items-center justify-center transition-colors duration-300 w-full h-full z-10 group-hover:bg-[#111118]">
                <span className="text-white group-hover:text-[#fb923c] text-[12px] sm:text-base font-bold flex items-center gap-3 tracking-wide transition-colors whitespace-nowrap">
                  {isLoggedIn ? 'Twój Panel Użytkownika' : 'Wypróbuj 7 Dni Za Darmo'}
                </span>
              </div>
            </Link>

          </motion.div>
        </motion.div>
      </main>

      {/* Sekcja Funkcji (Korzyści) */}
      <section id="features" className="scroll-mt-24 relative z-30 py-32 px-6 lg:px-12 max-w-[1400px] mx-auto mt-12 bg-[#0a0a0e]">
        <div className="mb-20 max-w-2xl relative">
          <div className="absolute -left-10 top-1/2 -translate-y-1/2 w-[200px] h-[200px] bg-purple-600/20 blur-[100px] rounded-full pointer-events-none" />
          
          <h2 className="relative text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight">
            Poznaj możliwości <span className="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400 whitespace-nowrap">Na&nbsp;dobranoc</span>
          </h2>
          <p className="relative text-xl text-slate-400 font-light leading-relaxed">Najbardziej zaawansowana aplikacja do usypiania na rynku. Przemyślana architektura stworzona przez ekspertów od snu.</p>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          
          {/* Duży blok - Tryb Offline */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-gradient-to-br from-[#1a1a24] to-[#0a0a0e] border border-white/10 hover:border-purple-500/40 md:col-span-2 transition-all duration-500 overflow-hidden shadow-2xl"
          >
            <div className="absolute inset-0 bg-gradient-to-r from-purple-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
            <div className="relative z-10 flex flex-col h-full justify-between">
              <div className="flex justify-between items-start mb-8">
                <div className="p-4 rounded-2xl bg-purple-500/10 border border-purple-500/20">
                  <WifiOff className="w-10 h-10 text-purple-400" />
                </div>
                <span className="text-xs font-bold uppercase tracking-widest text-purple-500/50">Priorytet Zdrowia</span>
              </div>
              <div>
                <h3 className="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Tryb Samolotowy</h3>
                <p className="text-slate-400 leading-relaxed font-light text-lg max-w-lg">
                  Wieczorem liczy się spokój. Dlatego wszystkie ulubione bajki możesz pobrać wcześniej i odtwarzać całkowicie offline, bez Internetu, powiadomień i rozpraszających bodźców.
                </p>
              </div>
            </div>
          </motion.div>

          {/* Mały blok - Biały szum */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ delay: 0.1, duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-[#111118] border border-white/5 hover:border-pink-500/30 transition-all duration-500 overflow-hidden"
          >
            <div className="absolute top-0 right-0 w-32 h-32 bg-pink-500/10 blur-[50px]" />
            <div className="relative z-10 flex flex-col h-full">
              <VolumeX className="w-10 h-10 text-pink-400 mb-8" />
              <h3 className="text-2xl font-bold text-white mb-4 tracking-tight">Dźwięki Tła</h3>
              <p className="text-slate-400 leading-relaxed font-light">
                Naturalne pejzaże dźwiękowe oraz kojące szumy zostały dobrane tak, aby stworzyć bezpieczną i relaksującą atmosferę, wspierając spokojne zasypianie każdego wieczoru.
              </p>
            </div>
          </motion.div>

          {/* Mały blok - Bajki */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ delay: 0.2, duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-[#111118] border border-white/5 hover:border-blue-500/30 transition-all duration-500 overflow-hidden"
          >
            <Sparkles className="w-10 h-10 text-blue-400 mb-8" />
            <h3 className="text-2xl font-bold text-white mb-4 tracking-tight">Biblioteka Bajek</h3>
            <p className="text-slate-400 leading-relaxed font-light">
              Każda bajka została stworzona z myślą o spokojnym zakończeniu dnia. Delikatna narracja, wyciszająca atmosfera i starannie dobrane historie pomagają dziecku naturalnie przejść od aktywności do snu.
            </p>
          </motion.div>

          {/* Duży blok - Licencja */}
          <motion.div 
            initial={{ opacity: 0, y: 40 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true, margin: "-100px" }} transition={{ delay: 0.3, duration: 0.6 }}
            className="group relative p-10 lg:p-14 rounded-[2rem] bg-gradient-to-bl from-[#1a1a24] to-[#0a0a0e] border border-white/10 hover:border-indigo-500/40 md:col-span-2 transition-all duration-500 overflow-hidden shadow-2xl"
          >
            <div className="absolute inset-0 bg-gradient-to-l from-indigo-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
            <div className="relative z-10 flex flex-col md:flex-row gap-10 items-center justify-between h-full">
              <div className="flex-1">
                <div className="flex items-center gap-4 mb-6">
                  <ShieldCheck className="w-8 h-8 text-indigo-400" />
                  <span className="text-sm font-bold uppercase tracking-widest text-indigo-400">Jedna opłata</span>
                </div>
                <h3 className="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Pełna Kontrola</h3>
                <p className="text-slate-400 leading-relaxed font-light text-lg max-w-xl">
                  Twoja licencja i urządzenia są zawsze pod ręką. Intuicyjny panel pozwala zarządzać wszystkim w jednym miejscu, zapewniając wygodę i pełną kontrolę nad kontem.
                </p>
              </div>
              <div className="w-full md:w-auto p-6 rounded-2xl bg-white/5 border border-white/10 flex flex-col gap-4 min-w-[200px]">
                <div className="flex items-center justify-between text-sm">
                  <span className="text-slate-400 font-medium">Urządzenie Mamy</span>
                  <Check className="w-4 h-4 text-emerald-400" />
                </div>
                <div className="w-full h-[1px] bg-white/10" />
                <div className="flex items-center justify-between text-sm">
                  <span className="text-slate-400 font-medium">Tablet (Pokój Dziecka)</span>
                  <Check className="w-4 h-4 text-emerald-400" />
                </div>
                <div className="w-full h-[1px] bg-white/10" />
                <div className="flex items-center justify-between text-sm">
                  <span className="text-slate-400 font-medium">Telefon Taty</span>
                  <Check className="w-4 h-4 text-emerald-400" />
                </div>
              </div>
            </div>
          </motion.div>
          
        </div>
      </section>

      {/* Dedykowana Galeria Zrzutów Ekranu */}
      <ScreenshotsSection />

      {/* Sekcja Wideo Promocyjnego */}
      <VideoSection />

      {/* Sekcja Jak To Działa */}
      <HowItWorksSection />

      {/* Sekcja Opinii Użytkowników */}
      <TestimonialsSection />

      {/* Sekcja Cennika */}
      <PricingSection />

      {/* Sekcja FAQ */}
      <FaqSection />

      {/* Sekcja Kontakt */}
      <ContactSection />

      {/* Główny Call To Action */}
      <CtaSection />

      {/* Stopka */}
      <Footer />
      </motion.div>

      {/* Pływający dolny pasek nawigacji TYLKO na urządzeniach mobilnych */}
      <div className="md:hidden fixed bottom-4 left-4 right-4 z-[80]">
        <div className="bg-gradient-to-r from-[#1a1a24]/90 to-[#0a0a0e]/90 backdrop-blur-xl border border-white/10 rounded-2xl p-2 flex items-center justify-between shadow-[0_10px_40px_rgba(0,0,0,0.8)]">
          
          <button onClick={(e) => { window.scrollTo({ top: 0, behavior: 'smooth' }); }} className="flex flex-col items-center justify-center flex-1 py-2 text-slate-400 hover:text-white hover:scale-105 transition-all">
            <Home className="w-5 h-5 mb-1" />
            <span className="text-[10px] font-bold tracking-wider uppercase">Start</span>
          </button>

          <button onClick={(e) => handleSmoothScroll(e, 'pricing')} className="flex flex-col items-center justify-center flex-1 py-2 text-purple-400 hover:text-purple-300 hover:scale-105 transition-all">
            <Diamond className="w-5 h-5 mb-1 drop-shadow-[0_0_8px_rgba(168,85,247,0.8)]" />
            <span className="text-[10px] font-bold tracking-wider uppercase">Cennik</span>
          </button>

          <Link href="/blog" className="flex flex-col items-center justify-center flex-1 py-2 text-slate-400 hover:text-white hover:scale-105 transition-all">
            <BookOpen className="w-5 h-5 mb-1" />
            <span className="text-[10px] font-bold tracking-wider uppercase">Blog</span>
          </Link>

          <Link href={isLoggedIn ? "/dashboard" : "/logowanie"} className="flex flex-col items-center justify-center flex-1 py-2 text-slate-400 hover:text-white hover:scale-105 transition-all">
            <User className={`w-5 h-5 mb-1 ${isLoggedIn ? 'text-purple-400' : ''}`} />
            <span className={`text-[10px] font-bold tracking-wider uppercase ${isLoggedIn ? 'text-purple-400' : ''}`}>{isLoggedIn ? 'Panel' : 'Konto'}</span>
          </Link>

        </div>
      </div>
    </div>
  );
}
