// Komponent Kontakt
function ContactSection() {
  const [name, setName] = useState('');
  const [email, setEmail] = useState('');
  const [message, setMessage] = useState('');
  const [isSent, setIsSent] = useState(false);
  const [isLoading, setIsLoading] = useState(false);

  const [isError, setIsError] = useState(false);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!name.trim() || !email.trim() || !message.trim()) return;
    setIsLoading(true);
    setIsError(false);
    const accessKey = "85a647de-819f-428b-9e78-ac375b7f6bf3";

    try {
      const response = await fetch("/api/contact", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          name: name,
          email: email,
          message: message,
        }),
      });

      const result = await response.json();
      if (result.success) {
        setIsSent(true);
        setIsError(false);
        setName('');
        setEmail('');
        setMessage('');
        setTimeout(() => setIsSent(false), 5000);
      } else {
        setIsError(true);
      }
    } catch (error) {
      setIsError(true);
      console.error(error);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <section id="contact" className="scroll-mt-24 relative z-30 py-32 px-6 lg:px-12 max-w-[1200px] mx-auto border-t border-white/5 mt-12">
      <div className="text-center mb-16 relative">
        <h2 className="text-3xl md:text-5xl font-bold text-white mb-6">
          Skontaktuj się z <span className="font-serif italic text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">nami</span>
        </h2>
        <p className="text-lg text-slate-400 font-light max-w-2xl mx-auto">
          Masz pytania, na które nie znalazłeś odpowiedzi w FAQ? Jesteśmy do Twojej dyspozycji i zazwyczaj odpowiadamy w 2 godziny.
        </p>
      </div>

      <div className="grid md:grid-cols-5 gap-12 items-start relative z-10">
        {/* Dane Kontaktowe (Lewa Strona) */}
        <div className="md:col-span-2 space-y-6">
          <div className="flex items-start gap-4 p-6 lg:p-8 rounded-[2rem] bg-[#111118]/80 border border-white/5 backdrop-blur-sm hover:border-purple-500/30 transition-colors">
            <div className="w-12 h-12 rounded-full bg-purple-500/10 border border-purple-500/20 flex items-center justify-center flex-shrink-0">
              <Mail className="w-5 h-5 text-purple-400" />
            </div>
            <div>
              <h4 className="text-xl font-bold text-white mb-1">Napisz do nas</h4>
              <p className="text-sm text-slate-400 font-light leading-relaxed mb-3">Odpowiadamy na wszystkie zapytania przedsprzedażowe i posprzedażowe.</p>
              <a href="mailto:kreatywna.droga@gmail.com" className="text-purple-400 font-semibold hover:text-pink-400 transition-colors">kreatywna.droga@gmail.com</a>
            </div>
          </div>

          <div className="flex items-start gap-4 p-6 lg:p-8 rounded-[2rem] bg-[#111118]/80 border border-white/5 backdrop-blur-sm hover:border-pink-500/30 transition-colors">
            <div className="w-12 h-12 rounded-full bg-pink-500/10 border border-pink-500/20 flex items-center justify-center flex-shrink-0">
              <MessageSquare className="w-5 h-5 text-pink-400" />
            </div>
            <div>
              <h4 className="text-xl font-bold text-white mb-1">Pomoc Techniczna</h4>
              <p className="text-sm text-slate-400 font-light leading-relaxed mb-3">Dla klientów posiadamy priorytetową linię wsparcia technicznego.</p>
              <a href="/kontakt" className="text-pink-400 font-semibold hover:text-purple-400 transition-colors">Otwórz zgłoszenie →</a>
            </div>
          </div>
        </div>

        {/* Formularz Kontaktowy (Prawa Strona) */}
        <div className="md:col-span-3">
          <form onSubmit={handleSubmit} className="p-8 lg:p-12 rounded-[2.5rem] bg-[#111118] border border-white/5 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
            <div className="grid md:grid-cols-2 gap-6 mb-6">
              <div>
                <label className="block text-sm font-semibold text-slate-300 mb-2">Twoje Imię</label>
                <input 
                  type="text" 
                  required
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  className="w-full bg-[#0a0a0e] border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-purple-500/50 transition-colors placeholder-slate-600 font-light" 
                  placeholder="Jak masz na imię?" 
                />
              </div>
              <div>
                <label className="block text-sm font-semibold text-slate-300 mb-2">Adres E-mail</label>
                <input 
                  type="email" 
                  required
                  value={email}
                  onChange={(e) => setEmail(e.target.value)}
                  className="w-full bg-[#0a0a0e] border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-purple-500/50 transition-colors placeholder-slate-600 font-light" 
                  placeholder="twoj@email.com" 
                />
              </div>
            </div>
            
            <div className="mb-8">
              <label className="block text-sm font-semibold text-slate-300 mb-2">Wiadomość</label>
              <textarea 
                rows={4} 
                required
                value={message}
                onChange={(e) => setMessage(e.target.value)}
                className="w-full bg-[#0a0a0e] border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:border-purple-500/50 transition-colors resize-none placeholder-slate-600 font-light" 
                placeholder="W czym możemy Ci dzisiaj pomóc?"
              ></textarea>
            </div>

            <button type="submit" disabled={isLoading || isSent} className="group w-full px-8 py-5 bg-gradient-to-r from-purple-600 to-pink-600 text-white font-extrabold rounded-full hover:scale-105 transition-all duration-300 shadow-[0_0_30px_rgba(236,72,153,0.3)] flex items-center justify-center gap-3 disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:scale-100">
              {isLoading ? 'Wysyłanie...' : isSent ? 'Wiadomość wysłana! 🚀' : 'Wyślij Wiadomość'} {!isLoading && !isSent && <Send className="w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />}
            </button>
            {isSent && (
              <p className="text-green-400 text-sm text-center mt-4">
                Dziękujemy za kontakt! Odezwiemy się najszybciej jak to możliwe.
              </p>
            )}
            {isError && (
              <p className="text-red-400 text-sm text-center mt-4">
                Wystąpił błąd podczas wysyłania. Spróbuj ponownie lub napisz bezpośrednio na kreatywna.droga@gmail.com.
              </p>
            )}
          </form>
        </div>
      </div>
    </section>
  );
}

function DemoModal({ onClose, isPremium = false }: { onClose: () => void, isPremium?: boolean }) {
  const demos = [
    { id: 1, title: 'Dobranoc, mały traktorze', duration: '0:30', color: 'from-emerald-500 to-green-500', url: 'https://pub-8791828a7ff445cb857b07c14f225bd7.r2.dev/storys/Kr%C3%B3tkie/Dobranoc%20ma%C5%82y%20traktorze/dobranoc%20ma%C5%82y%20traktorze.m4a' },
    { id: 2, title: 'Festiwal latających wysp', duration: '0:30', color: 'from-blue-500 to-indigo-500', url: 'https://pub-8791828a7ff445cb857b07c14f225bd7.r2.dev/storys/Spokojne/Festival%20lataj%C4%85cych%20wysp/FESTIWAL%20LATAJ%C4%84CYCH%20WYSP.m4a' },
    { id: 3, title: 'Ekspedycja na Wyspę...', duration: '0:30', color: 'from-purple-500 to-pink-500', url: 'https://pub-8791828a7ff445cb857b07c14f225bd7.r2.dev/storys/Przygodowe/Ekspedycja%20na%20Wysp%C4%99%20Cyfrowego%20Zegarmistrza/Ekspedycja%20na%20Wysp%C4%99%20Cyfrowego%20Zegarmistrza.m4a' },
  ];

  const [playingId, setPlayingId] = useState<number | null>(null);
  const audioRefs = useRef<{ [key: number]: HTMLAudioElement | null }>({});

  // Monitor playback to pause after 30s
  useEffect(() => {
    if (isPremium) return; // Użytkownicy Premium słuchają bez limitu czasowego
    
    let interval: ReturnType<typeof setInterval>;
    if (playingId) {
      interval = setInterval(() => {
        const audio = audioRefs.current[playingId];
        if (audio && audio.currentTime >= 30) {
          audio.pause();
          setPlayingId(null);
        }
      }, 1000);
    }
    return () => clearInterval(interval);
  }, [playingId]);

  // Clean up when modal closes
  useEffect(() => {
    return () => {
      Object.values(audioRefs.current).forEach(audio => {
        if (audio) {
          audio.pause();
        }
      });
    };
  }, []);

  const togglePlay = (id: number) => {
    if (playingId === id) {
      // Pause if clicking the currently playing track
      audioRefs.current[id]?.pause();
      setPlayingId(null);
    } else {
      // Pause all others first
      Object.values(audioRefs.current).forEach(audio => {
        if (audio) audio.pause();
      });
      
      const audioToPlay = audioRefs.current[id];
      if (audioToPlay) {
        audioToPlay.currentTime = 0; // start from beginning
        const playPromise = audioToPlay.play();
        if (playPromise !== undefined) {
          playPromise
            .then(() => {
              setPlayingId(id);
            })
            .catch(err => {
              console.error("Audio playback failed:", err);
              setPlayingId(null);
            });
        }
      }
    }
  };

  return (
    <motion.div 
      initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
      className="fixed inset-0 z-[100] flex items-center justify-center p-4 md:p-6"
    >
      <div className="absolute inset-0 bg-[#0a0a0e]/90 backdrop-blur-md" onClick={onClose} />
      <motion.div 
        initial={{ scale: 0.95, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.95, y: 20 }}
        className="relative w-full max-w-lg bg-[#111118] border border-white/10 rounded-3xl p-6 md:p-8 shadow-2xl overflow-hidden"
      >
        <div className="absolute top-0 right-0 w-[200px] h-[200px] bg-purple-500/10 blur-[60px] pointer-events-none" />
        
        <div className="flex justify-between items-center mb-8 relative z-10">
          <div>
            <h3 className="text-2xl font-bold text-white mb-1">Posłuchaj Próbek</h3>
            <p className="text-slate-400 text-sm">Zanurz się w świecie &quot;Na Dobranoc&quot;</p>
          </div>
          <button onClick={onClose} className="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors">
            <X className="w-5 h-5 text-white" />
          </button>
        </div>

        <div className="space-y-4 relative z-10">
          {demos.map(demo => (
            <div key={demo.id} className="flex items-center gap-4 p-4 rounded-2xl bg-white/5 hover:bg-white/10 border border-white/5 transition-colors">
              <button 
                onClick={() => togglePlay(demo.id)}
                className={`w-12 h-12 rounded-full bg-gradient-to-br ${demo.color} flex items-center justify-center shadow-lg hover:scale-105 transition-transform shrink-0`}
              >
                {playingId === demo.id ? <Pause className="w-5 h-5 text-white" fill="currentColor" /> : <PlayCircle className="w-5 h-5 text-white" />}
              </button>
              <div className="flex-1">
                <h4 className="font-bold text-white text-base leading-tight mb-1">{demo.title}</h4>
                <p className="text-xs text-slate-400 font-medium tracking-wide">{demo.duration}</p>
              </div>
              {playingId === demo.id && (
                <div className="flex gap-1 items-end h-5">
                  <span className="w-1.5 bg-purple-400 h-full animate-[bounce_1s_infinite]" />
                  <span className="w-1.5 bg-pink-400 h-3 animate-[bounce_1.2s_infinite]" />
                  <span className="w-1.5 bg-blue-400 h-4 animate-[bounce_0.8s_infinite]" />
                </div>
              )}
              
              <audio 
                ref={el => { audioRefs.current[demo.id] = el; }} 
                src={demo.url} 
                preload="metadata"
                onEnded={() => setPlayingId(null)} 
              />
            </div>
          ))}
        </div>
      </motion.div>
    </motion.div>
  );
}

export default function LandingPage() {
  const { scrollY } = useScroll();
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const [showDemoModal, setShowDemoModal] = useState(false);
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [isPremium, setIsPremium] = useState(false);

  useEffect(() => {
    const fetchProfile = async (userId: string) => {
      const { data } = await supabase
        .from('profiles')
        .select('is_premium')
        .eq('id', userId)
        .single();
      setIsPremium(!!data?.is_premium);
    };

    const checkUser = async () => {
      const { data: { session } } = await supabase.auth.getSession();
      setIsLoggedIn(!!session);
      if (session?.user) {
        fetchProfile(session.user.id);
      } else {
        setIsPremium(false);
      }
    };
    checkUser();

    const { data: authListener } = supabase.auth.onAuthStateChange((event, session) => {
      setIsLoggedIn(!!session);
      if (session?.user) {
        fetchProfile(session.user.id);
      } else {
        setIsPremium(false);
      }
    });

    return () => {
      authListener.subscription.unsubscribe();
    };
  }, []);

  const handleSmoothScroll = (e: React.MouseEvent<HTMLElement>, id: string) => {
    e.preventDefault();
    if (isMenuOpen) {
      setIsMenuOpen(false);
      // Jeśli klikamy z menu, strona jest pomniejszona (scale 0.9).
      // Czekamy 600ms aż wróci do 1.0, żeby współrzędne Y sekcji przeliczyły się poprawnie!
      setTimeout(() => {
        const element = document.getElementById(id);
        if (element) element.scrollIntoView({ behavior: 'smooth' });
      }, 600);
    } else {
      const element = document.getElementById(id);
      if (element) element.scrollIntoView({ behavior: 'smooth' });
    }
  };

  // Blokowanie scrolla pod spodem, gdy menu jest otwarte
  useEffect(() => {
    if (isMenuOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = 'unset';
    }
    return () => { document.body.style.overflow = 'unset'; };
  }, [isMenuOpen]);
  
  // Parallax: lewy telefon szybko w górę, prawy powoli w dół
  const yParallax1 = useTransform(scrollY, [0, 1000], [0, -400]);
  const yParallax2 = useTransform(scrollY, [0, 1000], [0, 250]);
  
  // Przenikanie tekstu (Fade out)
  const textOpacity = useTransform(scrollY, [0, 400], [1, 0]);
  const textScale = useTransform(scrollY, [0, 400], [1, 0.95]);

  return (
    <div className="min-h-screen bg-[#0a0a0e] overflow-x-hidden selection:bg-purple-500/30">
      
      {/* MODAL DEMO AUDIO */}
      <AnimatePresence>
        {showDemoModal && <DemoModal onClose={() => setShowDemoModal(false)} isPremium={isPremium} />}
      </AnimatePresence>

      {/* WYSUWANE MENU BOCZNE */}
      <AnimatePresence>
        {isMenuOpen && (
          <>
            {/* Niewidzialna nakładka zamykająca po kliknięciu poza menu */}
            <motion.div 
              initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
              onClick={() => setIsMenuOpen(false)}
              className="fixed inset-0 z-[90] bg-transparent cursor-pointer"
            />
            
            <motion.div
              initial={{ x: '100%', opacity: 0 }}
              animate={{ x: 0, opacity: 1 }}
              exit={{ x: '100%', opacity: 0 }}
              transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}
              style={{ willChange: 'transform, opacity' }}
              className="fixed top-0 right-0 bottom-0 w-[85vw] md:w-[450px] bg-gradient-to-br from-[#1a1a24]/95 to-[#0a0a0e]/95 backdrop-blur-3xl border-l border-t border-white/10 rounded-l-[2rem] md:rounded-l-[3rem] z-[100] p-6 md:p-8 flex flex-col shadow-[inset_1px_1px_0_rgba(255,255,255,0.1),-40px_0_100px_rgba(0,0,0,0.9)] overflow-y-auto overflow-x-hidden"
            >
              {/* Animowany błysk (Glass Sweep) przechodzący co kilka sekund */}
              <motion.div 
                animate={{ left: ['-100%', '200%', '200%'] }}
                transition={{ repeat: Infinity, duration: 6, ease: "linear", times: [0, 0.3, 1] }}
                className="absolute top-0 bottom-0 w-[60%] bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-[-25deg] pointer-events-none z-0"
              />

              {/* Przycisk Zamknij */}
              <div className="flex justify-end mb-6 relative z-10">
                <button onClick={() => setIsMenuOpen(false)} className="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 hover:rotate-90 transition-all border border-white/5">
                  <X className="w-5 h-5 text-white" />
                </button>
              </div>

              {/* Główne Linki Nawigacyjne */}
              <div className="flex flex-col gap-2.5 sm:gap-4 mb-auto text-lg sm:text-xl md:text-2xl font-bold tracking-tight relative z-10 overflow-y-auto max-h-[45vh] pr-2 custom-scrollbar">
                <Link href="/o-aplikacji" onClick={() => setIsMenuOpen(false)} className="xl:hidden text-slate-300 hover:text-white hover:translate-x-2 transition-all">O aplikacji</Link>
