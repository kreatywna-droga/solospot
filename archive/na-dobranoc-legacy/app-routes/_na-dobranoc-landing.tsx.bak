// Komponent pojedynczej komety, która po każdym locie losuje nowe miejsce startu, kąt i prędkość
function Comet({ initialDelay }: { initialDelay: number }) {
  const [config, setConfig] = useState({ top: 0, left: 0, angle: 0, duration: 4, size: 1 });
  const [isMounted, setIsMounted] = useState(false);
  const [key, setKey] = useState(0);

  const randomize = () => {
    // 0 = od prawej, 1 = od lewej, 2 = z góry, 3 = z dołu
    const side = Math.floor(Math.random() * 4);
    let top = 0, left = 0, angle = 0;
    
    if (side === 0) { // od prawej (leci w lewo)
      top = Math.random() * 100; left = 110; angle = 135 + (Math.random() * 90 - 45); 
    } else if (side === 1) { // od lewej (leci w prawo)
      top = Math.random() * 100; left = -10; angle = 0 + (Math.random() * 90 - 45); 
    } else if (side === 2) { // z góry (leci w dół)
      top = -10; left = Math.random() * 100; angle = 90 + (Math.random() * 90 - 45); 
    } else { // z dołu (leci w górę)
      top = 110; left = Math.random() * 100; angle = -90 + (Math.random() * 90 - 45); 
    }

    setConfig({ 
      top, left, angle, 
      duration: 1.5 + Math.random() * 3, // szybkie (1.5s) lub powolne w oddali (4.5s)
      size: 0.3 + Math.random() * 0.9 // małe w oddali lub duże blisko
    });
    setKey(prev => prev + 1); // Zmiana key resetuje animację framer-motion
  };

  useEffect(() => {
    randomize();
    const timer = setTimeout(() => setIsMounted(true), initialDelay * 1000);
    return () => clearTimeout(timer);
  }, [initialDelay]);

  if (!isMounted) return null;

  return (
    <div className="absolute" style={{ top: `${config.top}%`, left: `${config.left}%`, transform: `rotate(${config.angle}deg)`, opacity: config.size }}>
      <motion.div
        key={key}
        className="relative flex items-center"
        style={{ width: `${120 * config.size}px`, height: `${2 * config.size}px` }}
        initial={{ x: 0, opacity: 0 }}
        animate={{ x: '150vw', opacity: [0, 1, 1, 0] }}
        transition={{ duration: config.duration, ease: "linear" }}
        onAnimationComplete={() => setTimeout(randomize, 6000 + Math.random() * 6000)} // kometa pojawia się co 6-12s
      >
        <div className="absolute inset-0 bg-gradient-to-r from-transparent via-purple-300/40 to-white/90 rounded-full blur-[1px]" />
        <div className="absolute right-0 bg-white rounded-full shadow-[0_0_15px_5px_rgba(255,255,255,0.8)]" style={{ width: `${4 * config.size}px`, height: `${4 * config.size}px` }} />
      </motion.div>
    </div>
  );
}

// Komponent renderujący migoczące i spadające gwiazdy po prawej stronie tła
function StarrySky() {
  return (
    <div className="absolute top-0 right-0 w-full lg:w-[55%] h-full pointer-events-none overflow-hidden z-0">
      {/* Migoczące gwiazdy (zmniejszona ilość dla lepszej wydajności) */}
      {[...Array(100)].map((_, i) => {
        // Pseudolosowe, ale deterministyczne pozycje, aby nie powodować Hydration Error i uniknąć sztucznych skupisk
        const top = Math.abs(Math.sin(i * 12.9898) * 43758.5453) % 100;
        const left = Math.abs(Math.cos(i * 78.233) * 43758.5453) % 100;
        const isBlinking = i % 2 === 0;
        return (
          <div
            key={`star-${i}`}
            className={`absolute bg-white rounded-full ${isBlinking ? 'animate-pulse' : 'opacity-40'}`}
            style={{ 
              top: `${top}%`, 
              left: `${left}%`,
              width: i % 3 === 0 ? '3px' : '2px',
              height: i % 3 === 0 ? '3px' : '2px',
              animationDuration: `${2 + (i % 4)}s`,
              animationDelay: `${(i * 0.3) % 2}s`
            }}
          />
        );
      })}
      
      {/* Dynamiczne komety, które same kontrolują swoje losowe przeloty co ok. 10 sekund */}
      <Comet initialDelay={2} />
      <Comet initialDelay={8} />
    </div>
  );
}

// Specjalna kometa powitalna, która leci od lewej do prawej nad wszystkimi elementami (w tym nad telefonem) po załadowaniu strony
function GreetingComet() {
  const [isMounted, setIsMounted] = useState(false);

  useEffect(() => {
    // Odpalamy niemal natychmiast po zamontowaniu
    const timer = setTimeout(() => setIsMounted(true), 100);
    return () => clearTimeout(timer);
  }, []);

  if (!isMounted) return null;

  return (
    <div className="absolute top-0 left-0 w-full h-screen overflow-hidden pointer-events-none z-0">
      {/* Start z lewej strony, nieco powyżej środka ekranu, lekko w dół (kąt 15 stopni) */}
      <div className="absolute" style={{ top: '25vh', left: '-10%', transform: 'rotate(15deg)' }}>
        <motion.div
          className="relative flex items-center"
          style={{ width: '180px', height: '3px' }}
          initial={{ x: 0, opacity: 0 }}
          animate={{ x: '120vw', opacity: [0, 1, 1, 0] }}
          transition={{ duration: 4.5, delay: 0.2, ease: "linear" }}
        >
          {/* Bardziej widoczny ogon komety powitalnej */}
          <div className="absolute inset-0 bg-gradient-to-r from-transparent via-purple-200/80 to-white rounded-full blur-[2px]" />
          {/* Bardzo jasna, widoczna z daleka główka */}
          <div className="absolute right-0 w-[6px] h-[6px] bg-white rounded-full shadow-[0_0_20px_8px_rgba(255,255,255,0.9)]" />
        </motion.div>
      </div>
    </div>
  );
}

function PhoneMockup({ src, alt, glowColor, className = "w-[280px] h-[580px]", priority = true, shadowOpacity = 0 }: { src: string, alt: string, glowColor: string, className?: string, priority?: boolean, shadowOpacity?: number }) {
  const depth = 25;
  return (
    <div className={`relative ${className}`} style={{ transformStyle: 'preserve-3d' }}>
      
      {/* 1. TYŁ I GRUBOŚĆ (Boczne płytki tworzące efekt 3D) */}
      {[...Array(depth)].map((_, i) => {
        const isMiddle = i > 0 && i < depth - 1;
        return (
          <div 
            key={i}
            className={`absolute inset-0 rounded-[1.5rem] md:rounded-[3rem] bg-[#1a1a24] ${i === depth - 1 ? 'border border-[#2a2a3b]' : ''} ${isMiddle ? 'hidden md:block' : ''}`}
            style={{ 
              transform: `translateZ(-${i + 1}px)`,
              boxShadow: i === depth - 1 ? `0 20px 60px ${glowColor}` : 'none'
            }}
          />
        );
      })}

      {/* Przyciemnienie plecków dla telefonów odwróconych tyłem do ekranu */}
      <motion.div 
        className="absolute inset-0 rounded-[1.5rem] md:rounded-[3rem] bg-[#050508] pointer-events-none"
        style={{ transform: `translateZ(-${depth + 0.5}px)` }}
        animate={{ opacity: shadowOpacity }}
        transition={{ duration: 0.5 }}
      />

      {/* 2. PLANSZA ZE ZRZUTEM EKRANU (Zabezpieczona przed przenikaniem) */}
      <div 
        className="absolute inset-0 rounded-[1.5rem] md:rounded-[3rem] border-[4px] md:border-[8px] border-[#1a1a24] bg-[#0a0a0e]"
        style={{ transform: 'translateZ(1px)', backfaceVisibility: 'hidden' }}
      >
        {/* Idealne docięcie zawartości (clip-path omija błąd overflow-hidden w WebKit 3D) */}
        <div className="absolute inset-0 w-full h-full [clip-path:inset(0_round_1.2rem)] md:[clip-path:inset(0_round_2.5rem)]">
          <Image src={src} alt={alt} fill sizes="(max-width: 768px) 140px, 280px" className="object-cover" priority={priority} />
          
          {/* Notch - wcięcie */}
          <div className="absolute top-0 inset-x-0 h-4 md:h-6 flex justify-center z-20">
            <div className="w-16 md:w-28 h-3 md:h-5 bg-[#1a1a24] rounded-b-lg md:rounded-b-2xl" />
          </div>

          {/* Poświata odblaskowa */}
          <div className="absolute inset-0 bg-gradient-to-tr from-transparent via-white/10 to-transparent pointer-events-none z-10" />

          {/* Maska przyciemniająca dla elementów z tyłu karuzeli */}
          <motion.div 
            className="absolute inset-0 bg-[#050508] pointer-events-none z-30"
            animate={{ opacity: shadowOpacity }}
            transition={{ duration: 0.5 }}
          />
        </div>
      </div>
    </div>
  );
}

// Komponent generujący wektorowe logo 3D (kostka z księżycem)
function Logo3D() {
  const depth = 15; // Grubość kostki logo
  return (
    <div 
      className="relative w-12 h-14 group-hover:scale-110 transition-transform duration-300" 
      style={{ transformStyle: 'preserve-3d', transform: 'rotateY(25deg) rotateX(15deg) rotateZ(-5deg)' }}
    >
      {/* Płonąca pochodnia (Zbalansowana poświata w przestrzeni za ikoną - minus 15%) */}
      <motion.div 
        className="absolute -inset-2 bg-fuchsia-500 rounded-full blur-[20px]"
        style={{ transform: `translateZ(-${depth + 5}px)` }}
        animate={{ 
          scale: [1, 1.21, 1], 
          opacity: [0.20, 0.45, 0.20] 
        }}
        transition={{ 
          duration: 3.5, 
          repeat: Infinity, 
          ease: "easeInOut" 
        }}
      />

      {/* Warstwy grubości logo */}
      {[...Array(depth)].map((_, i) => (
        <div 
          key={i}
          className="absolute inset-0 bg-[#3f196a] rounded-xl"
          style={{ 
            transform: `translateZ(-${i + 1}px)`,
            boxShadow: i === depth - 1 ? `0 10px 20px rgba(0,0,0,0.5)` : 'none'
          }}
        />
      ))}
      
      {/* Front logo */}
      <div 
        className="absolute inset-0 bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 rounded-xl flex items-center justify-center border-t border-white/30"
        style={{ transform: 'translateZ(0)' }}
      >
        <div className="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent rounded-xl pointer-events-none" />
        <Moon className="w-7 h-7 text-white drop-shadow-lg relative z-10" />
      </div>
    </div>
  );
}

