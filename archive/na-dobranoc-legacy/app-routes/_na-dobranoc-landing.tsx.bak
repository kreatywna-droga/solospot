// Komponent z FAQ
function FaqSection() {
  const faqs = [
    { 
      q: "Jak działa 7-dniowy okres próbny?", 
      a: "Po rejestracji automatycznie otrzymujesz pełen, bezpłatny dostęp do wszystkich funkcji Premium na 7 dni. Po upływie tego czasu dostęp wygasa do momentu jednorazowego zakupu licencji. Nie wymagamy podawania karty płatniczej z góry – nie ma u nas automatycznych odnowień." 
    },
    { 
      q: "Czy mogę odtwarzać bajki przy zablokowanym ekranie?", 
      a: "Tak! Nasza aplikacja pozwala na odtwarzanie dźwięku w tle. Możesz włączyć wybraną historię, wygasić ekran telefonu i odłożyć urządzenie. Oszczędza to baterię oraz eliminuje światło niebieskie w pokoju zasypiającego dziecka." 
    },
    { 
      q: "Czy po zakupie ponoszę jeszcze jakieś koszty?", 
      a: "Absolutnie nie. Oferujemy prosty model: jednorazowa płatność za dożywotni dostęp (Lifetime). W aplikacji nie ma ukrytych mikropłatności, abonamentów ani wyskakujących reklam, które mogłyby zakłócić sen dziecka." 
    },
    { 
      q: "Dla jakiej grupy wiekowej przeznaczone są bajki?", 
      a: "Treści tworzone są z myślą o dzieciach w wieku od 2 do 8 lat. Słownictwo, tempo narracji oraz częstotliwości dźwięków tła są dobierane tak, by stymulować wyobraźnię, jednocześnie skutecznie wyciszając układ nerwowy malucha." 
    },
    { 
      q: "Na ilu urządzeniach mogę być zalogowany?", 
      a: "W ramach jednej licencji Premium możesz korzystać z aplikacji na 3 różnych urządzeniach jednocześnie. Dzięki temu bez problemu uruchomisz bajkę ze swojego telefonu, telefonu partnera lub domowego tabletu." 
    },
  ];

  return (
    <section id="faq" className="scroll-mt-24 relative z-30 py-32 px-6 lg:px-12 max-w-[800px] mx-auto mt-12">
      <div className="text-center mb-16">
        <h2 className="text-3xl md:text-5xl font-bold text-white mb-6">Często zadawane pytania</h2>
        <p className="text-lg text-slate-400 font-light">Wszystko, co musisz wiedzieć przed startem.</p>
      </div>

      <div className="space-y-4">
        {faqs.map((faq, i) => (
          <details key={i} className="group p-6 lg:p-8 rounded-[2rem] bg-[#111118]/80 backdrop-blur-sm border border-white/5 cursor-pointer hover:border-white/10 transition-colors">
            <summary className="flex items-center justify-between font-bold text-lg text-white list-none [&::-webkit-details-marker]:hidden">
              {faq.q}
              <div className="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center group-open:rotate-90 transition-transform">
                <ChevronRight className="w-4 h-4 text-purple-400" />
              </div>
            </summary>
            <p className="mt-6 text-slate-400 font-light leading-relaxed border-t border-white/5 pt-6">
              {faq.a}
            </p>
          </details>
        ))}
      </div>
    </section>
  );
}

// Stopka (Footer)
function Footer() {
  const router = useRouter();
  const [clickCount, setClickCount] = useState(0);

  const handleAdminClick = () => {
    const newCount = clickCount + 1;
    setClickCount(newCount);
    if (newCount >= 7) {
      router.push('/admin');
      setClickCount(0); // Reset after redirect
    }
  };

  return (
    <footer className="relative z-30 border-t border-white/5 bg-[#0a0a0e]/80 backdrop-blur-lg pt-16 pb-8 px-6 lg:px-12 mt-20">
      <div className="max-w-[1200px] mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <div className="flex items-center gap-3 opacity-80 hover:opacity-100 transition-opacity">
          <Moon className="w-6 h-6 text-purple-500" />
          <span className="text-xl font-serif font-black tracking-tighter text-white">na.dobranoc</span>
        </div>
        <div className="flex flex-wrap justify-center gap-6 md:gap-8 text-[13px] font-bold text-slate-500 mt-4 md:mt-0">
          <Link href="/regulamin" className="hover:text-purple-400 transition-colors">Regulamin Usługi</Link>
          <Link href="/prywatnosc" className="hover:text-purple-400 transition-colors">Polityka Prywatności</Link>
          <Link href="/cookies" className="hover:text-purple-400 transition-colors">Cookies</Link>
          <Link href="/zwroty" className="hover:text-purple-400 transition-colors">Zwroty i Reklamacje</Link>
          <Link href="/eula" className="hover:text-purple-400 transition-colors">EULA</Link>
          <Link href="/centrum-pomocy" className="hover:text-purple-400 transition-colors">Centrum Pomocy</Link>
          <Link href="/blog" className="hover:text-purple-400 transition-colors">Blog</Link>
          <Link href="/kontakt" className="hover:text-purple-400 transition-colors">Kontakt</Link>
        </div>
        <div className="text-[12px] text-slate-600 font-medium flex items-center justify-center gap-2 mt-4 md:mt-0">
          <span>&copy; {new Date().getFullYear()} <span onClick={handleAdminClick} className="cursor-default select-none">dst.design</span>. Wszelkie prawa zastrzeżone.</span>
        </div>
      </div>
    </footer>
  );
}

